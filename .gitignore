# ============================================================
#  .gitignore — Static HTML/CSS/JS Sites on Vercel
# ============================================================

# ── Vercel ──────────────────────────────────────────────────
.vercel

# ── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Build / dist outputs ─────────────────────────────────────
dist/
build/
out/
.output/
.nuxt/
.next/

# ── Environment & secrets ────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production
.env.production.local
.env*.local

# ── OS files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Editor & IDE ─────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.history/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Temp & cache ─────────────────────────────────────────────
.cache/
.temp/
.tmp/
tmp/
temp/

# ── Archives & compressed ────────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z

# ── Image originals (keep only web-optimised copies) ─────────
# Uncomment if you store raw assets locally:
# raw-assets/
# psd/
# *.psd
# *.ai
# *.sketch
# *.fig

# ── Misc ─────────────────────────────────────────────────────
.sass-cache/
*.css.map
*.js.map
.eslintcache
.stylelintcache
